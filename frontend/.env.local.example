# Copy to frontend/.env.local and fill in actual values. DO NOT commit .env.local.
#
# 백엔드(Python)용은 루트 .env 에 별도 관리 (.env.example 참고)

# Supabase (https://supabase.com/dashboard > Settings > API)
# Project URL — 백엔드의 SUPABASE_URL 과 동일한 값
NEXT_PUBLIC_SUPABASE_URL=
# anon/public key — 브라우저에 노출되는 읽기 전용 키
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Logo.dev — 종목 로고 이미지 (https://logo.dev 에서 무료 가입 후 발급)
# 없으면 이니셜 아바타로 fallback
NEXT_PUBLIC_LOGODEV_TOKEN=
