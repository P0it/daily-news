# Copy to .env and fill in actual values. DO NOT commit .env.

# DART Open API (https://opendart.fss.or.kr)
DART_API_KEY=

# Kakao Developers (https://developers.kakao.com)
# 앱 등록 후 "앱 설정 > 앱 키 > REST API 키"
KAKAO_REST_API_KEY=
# 카카오 로그인 > Redirect URI 등록한 값
KAKAO_REDIRECT_URI=http://localhost:8080/callback

# DO NOT SET THIS - Claude Code가 Max 플랜 대신 API 과금을 쓰게 됨 (P2 원칙)
# ANTHROPIC_API_KEY=

# Optional: Ollama fallback (기본 disabled)
OLLAMA_ENABLED=0
OLLAMA_MODEL=qwen2.5:14b

# Vercel 에 배포된 앱 URL (카톡 링크 베이스)
VERCEL_BASE_URL=https://news-briefing.vercel.app
