# 루트 .env 에 실제 값을 채워 사용. .env 는 절대 커밋하지 말 것.
#
# 프론트엔드는 런타임엔 정적 JSON만 읽지만, 빌드시 prebuild 스크립트가
# Supabase(원본)에서 데이터를 끌어와 정적 파일을 생성한다. 따라서 Vercel
# 프로젝트 환경변수에 SUPABASE_URL·SUPABASE_SERVICE_KEY 를 등록해야 한다
# (로컬 dev 는 이 루트 .env 를 자동 폴백으로 읽음).

# ── 필수 ──────────────────────────────────────────────────────────────
# Supabase (https://supabase.com/dashboard > Settings > API)
SUPABASE_URL=
# service_role key — 서버(Python)에서만 사용, 절대 공개 금지
SUPABASE_SERVICE_KEY=

# ── 수집기 ────────────────────────────────────────────────────────────
# DART Open API (https://opendart.fss.or.kr)
DART_API_KEY=

# SEC EDGAR — 실제 이름 + 이메일 형식 필수. 예: "Hong Gildong hong@example.com"
EDGAR_USER_AGENT=

# ── 알림 ──────────────────────────────────────────────────────────────
# Discord 웹훅 URL (채널 설정 > 연동 > 웹훅)
DISCORD_WEBHOOK_URL=

# ── 배포 ──────────────────────────────────────────────────────────────
# 브리핑 링크 베이스 URL
VERCEL_BASE_URL=https://news-briefing.vercel.app
# Vercel Deploy Hook URL (Project Settings > Git > Deploy Hooks).
# morning 실행 후 이 URL 로 POST 해 배포 서버가 DB에서 다시 빌드하게 한다.
# 미설정 시 자동 재배포는 스킵(로컬 전용 머신 등).
VERCEL_DEPLOY_HOOK_URL=

# ── 선택 — Ollama 로컬 LLM (기본 비활성) ────────────────────────────
OLLAMA_ENABLED=0
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── 금지 ──────────────────────────────────────────────────────────────
# 설정하면 Max 플랜 대신 API 과금 발생 (P2 원칙)
# ANTHROPIC_API_KEY=
